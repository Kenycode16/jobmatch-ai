{
    "manifest_version": 3,
    "name": "JobMatchAI",
    "version": "1.0",
    "description": "LinkedIn job scraper and AI resume matcher",
    "permissions": [
        "tabs",
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://www.linkedin.com/*"
    ],
    "action": {
        "default_popup": "popup/popup.html"
    },
    "content_scripts": [
        {
            "matches": ["https://www.linkedin.com/jobs/*"],
            "js": ["content/scraper.js"],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "service_worker": "background/service-worker.js"
    }
}